{
  "name": "shoptimity",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,workers -c cyan,yellow \"next dev --turbopack\" \"tsx --env-file=.env workers/index.ts\"",
    "dev:next": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:reset": "drizzle-kit push --force-reset",
    "db:studio": "drizzle-kit studio",
    "workers": "tsx --env-file=.env workers/index.ts",
    "db:seed": "tsx --env-file=.env db/seed.ts",
    "scripts/migrate-payments-fix": "tsx --env-file=.env scripts/migrate-payments-fix.ts",
    "make-admin": "tsx scripts/make-admin.ts",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\""
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1021.0",
    "@aws-sdk/s3-request-presigner": "^3.1021.0",
    "@base-ui/react": "^1.3.0",
    "@better-fetch/fetch": "^1.1.21",
    "@number-flow/react": "^0.6.0",
    "@react-email/components": "^1.0.11",
    "@stripe/react-stripe-js": "^6.2.0",
    "@stripe/stripe-js": "^9.3.1",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.5.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "country-state-city": "^3.2.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "input-otp": "^1.4.2",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "posthog-js": "^1.364.7",
    "posthog-node": "^5.28.11",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-email": "^5.2.10",
    "react-resizable-panels": "^4.8.0",
    "recharts": "3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "stripe": "^21.0.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
